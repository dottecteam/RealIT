// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User { 
  id    Int     @id @default(autoincrement()) 
  email String  @unique
  name  String?
  password String
} 

model Dados {
  id Int @id @default(autoincrement())
  data_base String
  uf String
  cliente String
  cnae_ocupacao String
  porte String
  carteira_inadiplencia String
  carteira_vencida Float?
}

model DadosPix {
  id Int @id @default(autoincrement())
  ano_mes           Int     // Corresponde ao Data-base AAAAMM
  municipio_ibge    Int     // Código IBGE do município
  municipio         String
  estado_ibge       Int     // Código IBGE do estado
  estado            String
  sigla_regiao      String
  vl_pagador_pf     Float   // Volume financeiro Pagador PF
  qt_pagador_pf     Int   // Quantidade de transações Pagador PF
  vl_recebedor_pf   Float   // Volume financeiro Recebedor PF
  qt_recebedor_pf   Int   // Quantidade de transações Recebedor PF
  qt_pes_pagador_pf Int   // Quantidade de pagadores PF
  qt_pes_recebedor_pf Int // Quantidade de recebedores PF
}

model TaxaEscolarizacao {
  id Int @id @default(autoincrement())
  nn	String // Unidade da Federação
  v	Float // Valor
  d1n	String // Unidade da Federação
  d3n	Int // Ano
  d5n	String // Grupo de idade
}

model CrescimentoPopulacional {
  id  Int @id @default(autoincrement())
  d1n String // Unidade da Federação
  d2n String // Taxa de crescimento geométrico
  v Float // Valor
}

model PopulacaoAbsoluta {
  id  Int @id @default(autoincrement())
  d1n String // Unidade da Federação
  d2n String // População residente
  v Int // Valor
}

model BonusDemografico {
  id Int    @id @default(autoincrement())
  brasilGrandeRegiaoUf String // Localidade
  total Int // População total
  xy_anos Int // População total da idade de x a y anos
}