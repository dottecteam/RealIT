// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum UserStatus {
  ADMIN
  ACTIVE
  INACTIVE
}

model User {
  id        Int        @id @default(autoincrement())
  email     String     @unique
  name      String?
  password  String
  createdAt DateTime   @default(now())
  status    UserStatus @default(ACTIVE) // Substitui o Role pelo Status solicitado
  sessions  Session[]
}

model Session {
  id           String   @id @default(uuid())
  userId       Int
  token        String   @unique
  deviceInfo   String?
  createdAt    DateTime @default(now())
  expiresAt    DateTime
  user         User     @relation(fields: [userId], references: [id])
  logs         Log[]
}

model Log {
  id        Int      @id @default(autoincrement())
  operation String   // Ex: "CREATE_SCORE", "UPDATE_USER"
  sessionId String
  createdAt DateTime @default(now())
  session   Session  @relation(fields: [sessionId], references: [id])
}

model RiscoCredito{
  id Int @id @default(autoincrement())
  mesAno String
  uf String
  regiao String
  inadiplenciaReal Float 
  fragilidadeRenda Float
  agingDivida Float
  vulnerabilidadeSocial Float
}

model inclusaoExpansao{
  id Int @id @default(autoincrement())
  mesAno String
  uf String
  regiao String
  maturidadePix Float 
  crescimentoPopulacional Float
  populacaoAbsoluta Float
  bonusDemografico Float
}

model FiltroScore{
  id Int @id @default(autoincrement())
  idUsuario Int
  mesInicial Int
  mesFinal Int
  inadiplenciaRealPeso Float 
  fragilidadeRendaPeso Float
  agingDividaPeso Float
  vulnerabilidadeSocialPeso Float
  maturidadePixPeso Float 
  crescimentoPopulacionalPeso Float
  populacaoAbsolutaPeso Float
  bonusDemograficoPeso Float
}

model EstruturaSrcPix{
  id Int @id @default(autoincrement())
  ano_mes String
  regiao String
  uf String
  tipo String
  classe String
  metrica String
  origem String
  valor Float
}

model EstruturaIBGE{
  id Int @id @default(autoincrement())
  ano String
  regiao String
  uf String
  taxa_escolarizacao Float
  populacao_residente Int
  taxa_crescimento Float
  variacao_populacao Int
}