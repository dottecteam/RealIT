// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User { 
  id    Int     @id @default(autoincrement()) 
  email String  @unique
  name  String?
  password String
} 

model Dados {
  id Int @id @default(autoincrement())
  data_base String
  uf String
  cliente String
  cnae_ocupacao String
  porte String
  carteira_inadiplencia Float
  carteira_vencida Float @default(0)
  carteira_ativa Float @default(0)
  carteira_acima_de_90_dias Float @default(0)
}

model DadosPix {
  id Int @id @default(autoincrement())
  ano_mes           Int     // Corresponde ao Data-base AAAAMM
  municipio_ibge    Int     // Código IBGE do município
  municipio         String
  estado_ibge       Int     // Código IBGE do estado
  estado            String
  sigla_regiao      String
  vl_pagador_pf     Float   // Volume financeiro Pagador PF
  qt_pagador_pf     Int   // Quantidade de transações Pagador PF
  qt_pes_pagador_pf Int   // Quantidade de pagadores PF
}

model TaxaEscolarizacao {
  id Int @id @default(autoincrement())
  nn	String // Unidade da Federação
  v	Float // Valor
  d1n	String // Unidade da Federação
  d3n	Int // Ano
  d5n	String // Grupo de idade
}

model CrescimentoPopulacional {
  id  Int @id @default(autoincrement())
  d1n String // Unidade da Federação
  d2n String // Taxa de crescimento geométrico
  v Float // Valor
}

model PopulacaoAbsoluta {
  id  Int @id @default(autoincrement())
  d1n String // Unidade da Federação
  d2n String // População residente
  v Int // Valor
}

model BonusDemografico {
  id Int    @id @default(autoincrement())
  brasilGrandeRegiaoUf String // Localidade
  total Int // População total
  xy_anos String // População total da idade de x a y anos
}

model RiscoCredito {
  id Int @id @default(autoincrement())
  inadimplenciaReal Float // Taxa de negativados (CPFs) ativos na UF
  FragilidadeRenda Float // Classe social
  AgingDivida Float // Tempo médio de atraso das dívidas em aberto
  VulnerabilidadeSocial Float // Escolaridade
}

model InclusaoDemografica {
  id Int @id @default(autoincrement())
  MaturidadePix Float // Volume e valores de transações per capita (P2B)
  CrescimentoPopulacional Float // Taxa de variação anual da população na UF
  PopulacaoAbsoluta Int // Total de habitantes (Mercado Endereçável)
  BonusDemografico Float // Idade média: Regiões jovens indica maior ciclo de vida
}